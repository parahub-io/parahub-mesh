#!/bin/sh
# Parahub Mesh — Yggdrasil inbound access control
# Blocks all inbound Yggdrasil traffic to private clients by default.
# Only whitelisted IPv6 addresses (300::/7 subnet) are reachable from outside.
#
# Usage: parahub-ygg-acl init|sync <ip1> <ip2> ...|add <ip>|remove <ip>|list

TABLE="inet parahub_ygg"

case "$1" in
  init)
    nft add table $TABLE 2>/dev/null
    nft flush table $TABLE 2>/dev/null
    nft add set $TABLE allowed '{ type ipv6_addr; }'
    nft add chain $TABLE ygg_filter '{ type filter hook forward priority -10; policy accept; }'

    # Allow established/related (responses to outbound connections from LAN)
    nft add rule $TABLE ygg_filter iifname "ygg0" oifname "br-private" ct state established,related accept

    # Allow inbound to whitelisted addresses
    nft add rule $TABLE ygg_filter iifname "ygg0" oifname "br-private" ip6 daddr @allowed accept

    # Drop all other inbound from Yggdrasil to private network
    nft add rule $TABLE ygg_filter iifname "ygg0" oifname "br-private" counter drop

    logger -t parahub-ygg-acl "Yggdrasil ACL initialized (deny by default)"
    ;;
  sync)
    # Flush and re-add all allowed IPs (called from heartbeat)
    nft flush set $TABLE allowed 2>/dev/null
    shift
    for IP in "$@"; do
      nft add element $TABLE allowed "{ $IP }" 2>/dev/null
    done
    COUNT=$#
    [ "$COUNT" -gt 0 ] && logger -t parahub-ygg-acl "Synced $COUNT allowed addresses"
    ;;
  add)
    [ -z "$2" ] && echo "Usage: $0 add <ipv6>" && exit 1
    nft add element $TABLE allowed "{ $2 }" 2>/dev/null
    logger -t parahub-ygg-acl "Added: $2"
    ;;
  remove)
    [ -z "$2" ] && echo "Usage: $0 remove <ipv6>" && exit 1
    nft delete element $TABLE allowed "{ $2 }" 2>/dev/null
    logger -t parahub-ygg-acl "Removed: $2"
    ;;
  list)
    nft list set $TABLE allowed 2>/dev/null
    ;;
  *)
    echo "Usage: $0 {init|sync <ip>...|add <ip>|remove <ip>|list}"
    exit 1
    ;;
esac
