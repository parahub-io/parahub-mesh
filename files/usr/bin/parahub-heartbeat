#!/bin/sh
# Phone-home heartbeat to Parahub cloud
PARAHUB_API_YGG="http://[<YGG_ADDR_MAIN>]/api/v1/iot/mesh/heartbeat"
PARAHUB_API_PUBLIC="https://parahub.io/api/v1/iot/mesh/heartbeat"
HEARTBEAT_KEY=$(grep '^HEARTBEAT_KEY=' /etc/parahub/secrets 2>/dev/null | cut -d= -f2)

# Read firmware role
ROLE=$(cat /etc/parahub/role 2>/dev/null || echo "unknown")

# Read identity from /etc/parahub/keys
. /etc/parahub/keys 2>/dev/null
MAC="${NODE_MAC:-$(cat /sys/class/net/br-lan/address 2>/dev/null)}"
HOSTNAME="$(uci -q get system.@system[0].hostname)"
YGG_ADDR="${YGGDRASIL_ADDRESS:-unknown}"
SSID="${PRIVATE_SSID:-unknown}"
UPTIME="$(cut -d. -f1 /proc/uptime)"

# Get mesh IP (br-private primary address, skip anycast/secondary)
MESH_IP=$(ip -4 addr show br-private 2>/dev/null | grep -o 'inet [0-9.]*' | head -1 | cut -d' ' -f2)
MESH_IP="${MESH_IP:-unknown}"

# Generate WireGuard VPS keypair if missing (OTA from pre-VPS firmware)
if [ "$ROLE" != "bee" ] && [ ! -f /etc/parahub/wg_vps_private.key ] && command -v wg >/dev/null 2>&1; then
    umask 077
    wg genkey > /etc/parahub/wg_vps_private.key
    wg pubkey < /etc/parahub/wg_vps_private.key > /etc/parahub/wg_vps_public.key
    logger -t parahub-heartbeat "Generated VPS WireGuard keypair (OTA migration)"
fi

# Read WireGuard VPS public key (Bumblebee only)
WG_PUBKEY=""
if [ -f /etc/parahub/wg_vps_public.key ]; then
    WG_PUBKEY=$(cat /etc/parahub/wg_vps_public.key 2>/dev/null)
fi

# Detect hardware from board_name
HW=$(cat /tmp/sysinfo/board_name 2>/dev/null)
case "$HW" in
    glinet,gl-axt1800) HW="axt1800" ;;
    glinet,gl-mt3000) HW="mt3000" ;;
    glinet,gl-mt6000) HW="mt6000" ;;
    xiaomi,redmi-router-ax6s) HW="ax6s" ;;
    asus,rt-ax53u) HW="ax53u" ;;
    glinet,gl-ar300m16) HW="ar300m16" ;;
    cudy,wr3000-v1) HW="wr3000" ;;
    *) HW="${HW:-unknown}" ;;
esac

FW_VERSION=$(cat /etc/parahub/version 2>/dev/null || echo "unknown")

# Detect VPN mode
VPN_MODE="none"
[ -f /etc/parahub/mullvad_account ] && VPN_MODE="mullvad"
[ "$VPN_MODE" = "none" ] && wg show vps_gateway 2>/dev/null | grep -q 'latest handshake' && VPN_MODE="vps"

PAYLOAD="{\"mac\":\"${MAC}\",\"hostname\":\"${HOSTNAME}\",\"yggdrasil_address\":\"${YGG_ADDR}\",\"firmware_version\":\"${FW_VERSION}\",\"hardware_profile\":\"${HW}\",\"uptime\":${UPTIME},\"private_ssid\":\"${SSID}\",\"firmware_role\":\"${ROLE}\",\"mesh_ip\":\"${MESH_IP}\",\"wg_public_key\":\"${WG_PUBKEY}\",\"vpn_mode\":\"${VPN_MODE}\"}"

RESPONSE=""

if [ "$ROLE" = "bee" ]; then
    # Bee: ensure internet reachability via batman-adv gateway when no WAN
    # Note: BusyBox "ip route show default" may return all routes — use grep filter
    if ! ip route 2>/dev/null | grep -q '^default'; then
        ANYCAST_GW="10.250.250.1"
        GW_IP=""

        # Try anycast gateway first (set by bumblebees in gw_mode=server)
        ip route replace "${ANYCAST_GW}/32" dev br-private 2>/dev/null
        if ping -c 1 -W 3 "$ANYCAST_GW" >/dev/null 2>&1; then
            GW_IP="$ANYCAST_GW"
            logger -t parahub-heartbeat "Bee: no WAN, using anycast mesh gateway $ANYCAST_GW"
        else
            ip route del "${ANYCAST_GW}/32" dev br-private 2>/dev/null

            # Fallback: derive gateway IP from batman-adv gateway MAC
            GW_LINE=$(batctl gwl 2>/dev/null | grep '^\*' | head -1)
            if [ -n "$GW_LINE" ]; then
                GW_MAC=$(echo "$GW_LINE" | awk '{print $2}')
                O4=$(echo "$GW_MAC" | awk -F: '{printf "%d", "0x"$4}')
                O5=$(echo "$GW_MAC" | awk -F: '{printf "%d", "0x"$5}')
                CANDIDATE="10.${O4}.${O5}.1"
                ip route replace "${CANDIDATE}/32" dev br-private 2>/dev/null
                if ping -c 1 -W 3 "$CANDIDATE" >/dev/null 2>&1; then
                    GW_IP="$CANDIDATE"
                    logger -t parahub-heartbeat "Bee: no WAN, using mesh gateway $GW_IP (MAC $GW_MAC)"
                else
                    ip route del "${CANDIDATE}/32" dev br-private 2>/dev/null
                fi
            fi
        fi

        if [ -n "$GW_IP" ]; then
            ip route replace default via "$GW_IP" dev br-private 2>/dev/null
        fi

        # Ensure DNS upstream is set (WAN DHCP may have cleared it)
        mkdir -p /tmp/resolv.conf.d
        grep -q nameserver /tmp/resolv.conf.d/resolv.conf.auto 2>/dev/null || \
            printf 'nameserver 1.1.1.1\nnameserver 8.8.8.8\n' >> /tmp/resolv.conf.d/resolv.conf.auto
    fi

    # Bee: try yggdrasil first (multicast-peered with bumblebees), fallback to public
    if ping6 -c 1 -W 3 <YGG_ADDR_MAIN> >/dev/null 2>&1; then
        RESPONSE=$(curl -s -m 10 -X POST \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer ${HEARTBEAT_KEY}" \
            -d "$PAYLOAD" \
            "${PARAHUB_API_YGG}" 2>/dev/null)
    fi
    if [ -z "$RESPONSE" ]; then
        RESPONSE=$(curl -s -m 10 -X POST \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer ${HEARTBEAT_KEY}" \
            -d "$PAYLOAD" \
            "${PARAHUB_API_PUBLIC}" 2>/dev/null)
    fi
else
    # Bumblebee: try yggdrasil first, fallback to public
    if ping6 -c 1 -W 3 <YGG_ADDR_MAIN> >/dev/null 2>&1; then
        RESPONSE=$(curl -s -m 10 -X POST \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer ${HEARTBEAT_KEY}" \
            -d "$PAYLOAD" \
            "${PARAHUB_API_YGG}" 2>/dev/null)
    fi
    if [ -z "$RESPONSE" ]; then
        RESPONSE=$(curl -s -m 10 -X POST \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer ${HEARTBEAT_KEY}" \
            -d "$PAYLOAD" \
            "${PARAHUB_API_PUBLIC}" 2>/dev/null)
    fi
fi

# Sync paid_clients to speed control (Bumblebee only)
if [ "$ROLE" != "bee" ] && [ -x /usr/bin/parahub-speed-control ] && [ -n "$RESPONSE" ]; then
    PAID_IPS=$(echo "$RESPONSE" | jsonfilter -e '$.paid_clients[*]' 2>/dev/null)
    # Flush and re-add all paid IPs
    parahub-speed-control flush
    for IP in $PAID_IPS; do
        parahub-speed-control add "$IP"
    done
fi

# Sync Yggdrasil ACL whitelist (Bumblebee only)
if [ "$ROLE" != "bee" ] && [ -x /usr/bin/parahub-ygg-acl ] && [ -n "$RESPONSE" ]; then
    YGG_IPS=$(echo "$RESPONSE" | jsonfilter -e '$.ygg_allowed[*]' 2>/dev/null)
    # Init nftables table if not yet created (OTA from pre-ACL firmware)
    nft list table inet parahub_ygg >/dev/null 2>&1 || parahub-ygg-acl init
    # Sync allowed set
    parahub-ygg-acl sync $YGG_IPS
fi

# VPS gateway auto-configuration (Bumblebee only, skip if Mullvad is configured)
if [ "$ROLE" != "bee" ] && [ -n "$RESPONSE" ] && [ ! -f /etc/parahub/mullvad_account ]; then
    VPS_ENDPOINT=$(echo "$RESPONSE" | jsonfilter -e '$.vps_gateway.endpoint' 2>/dev/null)
    VPS_PUBKEY=$(echo "$RESPONSE" | jsonfilter -e '$.vps_gateway.public_key' 2>/dev/null)
    VPS_IP=$(echo "$RESPONSE" | jsonfilter -e '$.vps_gateway.assigned_ip' 2>/dev/null)
    VPS_KEEPALIVE=$(echo "$RESPONSE" | jsonfilter -e '$.vps_gateway.keepalive' 2>/dev/null)

    if [ -n "$VPS_ENDPOINT" ] && [ -n "$VPS_PUBKEY" ] && [ -n "$VPS_IP" ]; then
        /usr/bin/parahub-vps-setup "$VPS_ENDPOINT" "$VPS_PUBKEY" "$VPS_IP" "${VPS_KEEPALIVE:-25}"
    fi
fi
