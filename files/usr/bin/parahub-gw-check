#!/bin/sh
# Parahub Gateway Health Check
# 3-state logic:
#   1. WG active → gw_mode=server (advertise as gateway, send GARP)
#   2. WG down + mesh gateway found → gw_mode=client + fallback routing through mesh
#   3. WG down + no mesh gateway → gw_mode=client (isolated, no guest internet)
#
# Run via cron every 2 minutes. Bumblebee only.

[ "$(cat /etc/parahub/role 2>/dev/null)" = "bumblebee" ] || exit 0

STATE_FILE="/tmp/mesh_gw_state"
GW_IP_FILE="/tmp/mesh_gw_ip"
ANYCAST_GW="10.250.250.1"
CURRENT_STATE=$(cat "$STATE_FILE" 2>/dev/null || echo "unknown")

# Read own subnets from /etc/parahub/keys
# Provides: GUEST_SUBNET (e.g. "10.131.196.0/24"), PRIVATE_SUBNET (e.g. "10.236.248.0/24")
. /etc/parahub/keys 2>/dev/null

# Detect guest interface name
GUEST_IFACE=$(ubus call network.interface.guest status 2>/dev/null | jsonfilter -e '@.l3_device' 2>/dev/null)

# ---- Check WireGuard health ----
WG_OK=0
if command -v wg >/dev/null 2>&1; then
    LAST_HS=$(wg show all latest-handshakes 2>/dev/null | awk '{print $NF}' | sort -rn | head -1)
    if [ -n "$LAST_HS" ] && [ "$LAST_HS" -gt 0 ] 2>/dev/null; then
        NOW=$(date +%s)
        AGE=$((NOW - LAST_HS))
        # Handshake within last 5 minutes = alive
        [ "$AGE" -lt 300 ] && WG_OK=1
    fi
fi

# ---- Cleanup mesh fallback routing ----
cleanup_mesh_fallback() {
    local old_gw
    old_gw=$(cat "$GW_IP_FILE" 2>/dev/null)

    # Remove mesh fallback nftables table (masquerade)
    nft delete table inet mesh_gw_fallback 2>/dev/null

    # Remove forward rule from fw4 by comment
    local handle
    handle=$(nft -a list chain inet fw4 forward_guest 2>/dev/null | grep 'mesh-gw-fallback' | awk '{print $NF}')
    [ -n "$handle" ] && nft delete rule inet fw4 forward_guest handle "$handle"

    # Remove mesh default routes and host route to gateway
    [ -n "$old_gw" ] && ip route del default via "$old_gw" dev br-private table 100 2>/dev/null
    [ -n "$old_gw" ] && ip route del "$old_gw/32" dev br-private 2>/dev/null
    ip route del default dev br-private metric 500 2>/dev/null

    rm -f "$GW_IP_FILE"
}

# ---- STATE 1: WireGuard active → server mode ----
if [ "$WG_OK" = "1" ]; then
    # Clean up mesh fallback if was active
    if [ "$CURRENT_STATE" = "mesh_fallback" ]; then
        cleanup_mesh_fallback
        # cleanup_mesh_fallback removed the mesh-fallback default; restore the
        # active WG's default in table 100 (netifd added it at ifup but the
        # earlier 'ip route replace' during fallback overwrote it).
        ACTIVE_WG=$(wg show all latest-handshakes 2>/dev/null | sort -k3 -rn | awk 'NR==1{print $1}')
        [ -n "$ACTIVE_WG" ] && ip route replace default dev "$ACTIVE_WG" table 100
        logger -t parahub-gw "WireGuard restored, removed mesh fallback (table 100 → $ACTIVE_WG)"
    fi

    CURRENT_MODE=$(batctl gw_mode 2>/dev/null | awk '{print $1}')
    if [ "$CURRENT_MODE" != "server" ]; then
        batctl gw_mode server
        logger -t parahub-gw "WireGuard active, switched to gw_mode=server"
    fi

    # Mesh return route: client nodes have different 10.x.y.0/24 subnets but share
    # L2 via bat0/br-private. Without this, reply packets to mesh clients go to WAN
    # instead of back through batman-adv. Lower metric than local /24 routes.
    ip route replace 10.0.0.0/8 dev br-private metric 500

    # Anycast gateway IP — bee nodes discover us via this well-known address
    ip addr replace "$ANYCAST_GW/32" dev br-private 2>/dev/null

    echo "server" > "$STATE_FILE"
    exit 0
fi

# WG is down — remove anycast gateway IP (only active servers should have it)
ip addr del "$ANYCAST_GW/32" dev br-private 2>/dev/null

# ---- WG is down, ensure client mode ----
CURRENT_MODE=$(batctl gw_mode 2>/dev/null | awk '{print $1}')
[ "$CURRENT_MODE" != "client" ] && batctl gw_mode client

# ---- Find best mesh gateway from batctl ----
GW_MAC=""
GW_LINE=$(batctl gwl 2>/dev/null | grep '^\*' | head -1)
if [ -n "$GW_LINE" ]; then
    # Format: "* aa:bb:cc:dd:ee:ff (255) ... [B.A.T.M.A.N. V]"
    GW_MAC=$(echo "$GW_LINE" | awk '{print $2}')
fi

if [ -z "$GW_MAC" ]; then
    # ---- STATE 3: No gateway — isolated ----
    if [ "$CURRENT_STATE" = "mesh_fallback" ]; then
        cleanup_mesh_fallback
        logger -t parahub-gw "Mesh gateway lost, guest internet disabled"
    fi
    echo "isolated" > "$STATE_FILE"
    exit 0
fi

# ---- STATE 2: Derive gateway IP from MAC and set up fallback ----
# MAC octets 4,5 → private subnet: 10.{octet4_dec}.{octet5_dec}.1
O4=$(echo "$GW_MAC" | awk -F: '{printf "%d", "0x"$4}')
O5=$(echo "$GW_MAC" | awk -F: '{printf "%d", "0x"$5}')
GW_IP="10.${O4}.${O5}.1"

# Add host route so we can reach gateway IP across mesh (different L3 subnets, same L2 via batman-adv)
ip route replace "$GW_IP/32" dev br-private

# Check if gateway is reachable on mesh
if ! ping -c 1 -W 2 "$GW_IP" >/dev/null 2>&1; then
    ip route del "$GW_IP/32" dev br-private 2>/dev/null
    # MAC-derived IP failed — try anycast gateway (handles mismatched NODE_MAC)
    ip route replace "$ANYCAST_GW/32" dev br-private 2>/dev/null
    if ping -c 1 -W 2 "$ANYCAST_GW" >/dev/null 2>&1; then
        GW_IP="$ANYCAST_GW"
        logger -t parahub-gw "MAC-derived IP unreachable, using anycast gateway $ANYCAST_GW"
    else
        ip route del "$ANYCAST_GW/32" dev br-private 2>/dev/null
        if [ "$CURRENT_STATE" = "mesh_fallback" ]; then
            cleanup_mesh_fallback
        fi
        logger -t parahub-gw "Mesh gateway unreachable (MAC-derived + anycast), skipping fallback"
        echo "isolated" > "$STATE_FILE"
        exit 0
    fi
fi

OLD_GW=$(cat "$GW_IP_FILE" 2>/dev/null)

# If gateway changed, clean up old one first (BEFORE updating GW_IP_FILE,
# since cleanup reads the file to determine which routes to remove)
if [ "$CURRENT_STATE" = "mesh_fallback" ] && [ "$OLD_GW" != "$GW_IP" ]; then
    cleanup_mesh_fallback
    logger -t parahub-gw "Mesh gateway changed: $OLD_GW -> $GW_IP"
fi

echo "$GW_IP" > "$GW_IP_FILE"

if [ "$CURRENT_STATE" != "mesh_fallback" ] || [ "$OLD_GW" != "$GW_IP" ]; then
    # Set up routing: table 100 for guest policy routing + main table for router's own traffic (DoH, NTP)
    ip route replace default via "$GW_IP" dev br-private table 100
    ip route replace default via "$GW_IP" dev br-private metric 500

    # Masquerade guest + private traffic to br-private IP (gateway only knows mesh L2 addresses).
    # Without private SNAT, Parahub clients (10.P1.P2.x) hit the mesh peer with their own src,
    # peer has no return route → reply lost → "no internet on Parahub WiFi".
    nft add table inet mesh_gw_fallback 2>/dev/null
    nft flush table inet mesh_gw_fallback
    nft add chain inet mesh_gw_fallback postrouting '{ type nat hook postrouting priority 100; }'
    nft add rule inet mesh_gw_fallback postrouting oifname "br-private" ip saddr "$GUEST_SUBNET" masquerade
    [ -n "$PRIVATE_SUBNET" ] && nft add rule inet mesh_gw_fallback postrouting oifname "br-private" ip saddr "$PRIVATE_SUBNET" masquerade

    # Allow guest→br-private forwarding (blocked by reject_to_lan in forward_guest)
    if [ -n "$GUEST_IFACE" ]; then
        if ! nft list chain inet fw4 forward_guest 2>/dev/null | grep -q 'mesh-gw-fallback'; then
            nft insert rule inet fw4 forward_guest iifname "$GUEST_IFACE" oifname "br-private" accept comment \"mesh-gw-fallback\"
        fi
    fi

    # Restart DoH proxy — it may have stopped when WAN was down
    /etc/init.d/https-dns-proxy restart 2>/dev/null

    logger -t parahub-gw "Mesh fallback active via gateway $GW_IP (MAC $GW_MAC)"
fi

echo "mesh_fallback" > "$STATE_FILE"
